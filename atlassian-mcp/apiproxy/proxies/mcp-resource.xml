<ProxyEndpoint name="mcp-resource">
  <Description>Atlassian MCP Resource Proxy Endpoint</Description>
  <FaultRules/>
  <PreFlow name="PreFlow">
    <Request>
      <Step>
        <Name>CORS-Allow</Name>
      </Step>
      <Step>
        <Name>AM-Capture-Original-Host</Name>
      </Step>
      <Step>
        <Name>EV-Extract-Tenant-Id</Name>
        <Condition>(proxy.pathsuffix MatchesPath "/oauth2/**") or (proxy.pathsuffix MatchesPath "/v1/mcp/authv2/*")</Condition>
      </Step>
      <Step>
        <Name>ParsePayload-MCP</Name>
        <Condition>(proxy.pathsuffix MatchesPath "/v1/mcp") and (request.verb = "POST")</Condition>
      </Step>
    </Request>
    <Response/>
  </PreFlow>
  <PostFlow name="PostFlow">
    <Request/>
    <Response/>
  </PostFlow>
  <Flows>
    <Flow name="openid-configuration">
      <Description>Atlassian-specific OpenID Connect discovery metadata</Description>
      <Request/>
      <Response>
        <Step>
          <Name>AM-Atlassian-OpenIdConfiguration</Name>
        </Step>
      </Response>
      <Condition>(proxy.pathsuffix MatchesPath "/oauth2/*/.well-known/openid-configuration") and (request.verb = "GET")</Condition>
    </Flow>
    <Flow name="oauth-authorization-server">
      <Description>Atlassian-specific OAuth 2.0 Authorization Server metadata</Description>
      <Request/>
      <Response>
        <Step>
          <Name>JavaScript-RewriteAuthServer</Name>
          <Condition>response.status.code = 200</Condition>
        </Step>
      </Response>
      <Condition>(proxy.pathsuffix MatchesPath "/oauth2/*/.well-known/oauth-authorization-server") and (request.verb = "GET")</Condition>
    </Flow>
    <Flow name="/authorize">
      <Description>Intercept authorize redirects</Description>
      <Request>
        <Step>
          <Name>PC-Client-Redirect-Uri</Name>
        </Step>
        <Step>
          <Name>PC-Client-Id</Name>
        </Step>
      </Request>
      <Response>
        <Step>
          <Name>AM-RedirectAuth</Name>
        </Step>
      </Response>
      <Condition>((proxy.pathsuffix MatchesPath "/oauth2/*/authorize") or (proxy.pathsuffix MatchesPath "/oauth2/authorize")) and (request.verb = "GET")</Condition>
    </Flow>
    <Flow name="/callback">
      <Description>Intercept authorization code redirect callback from Atlassian</Description>
      <Request>
        <Step>
          <Name>LC-Client-Redirect-Uri</Name>
        </Step>
        <Step>
          <Name>RF-Session-Expired</Name>
          <Condition>oauth_client_redirect_uri == null</Condition>
        </Step>
      </Request>
      <Response>
        <Step>
          <Name>AM-RedirectToClient</Name>
        </Step>
        <Step>
          <Name>IC-Client-Redirect-Uri</Name>
        </Step>
      </Response>
      <Condition>(proxy.pathsuffix MatchesPath "/oauth2/callback") and (request.verb = "GET")</Condition>
    </Flow>
    <Flow name="/token">
      <Description>Dynamic Token Exchange intercept</Description>
      <Request/>
      <Response/>
      <Condition>((proxy.pathsuffix MatchesPath "/oauth2/*/token") or (proxy.pathsuffix MatchesPath "/oauth2/token")) and (request.verb = "POST")</Condition>
    </Flow>
    <Flow name="mcp-v1">
      <Description>MCP v1 Endpoint</Description>
      <Request>
        <Step>
          <Name>RF-Unauthorized</Name>
          <Condition>request.header.Authorization == null</Condition>
        </Step>
        <Step>
          <Name>AM-Hash-Token</Name>
        </Step>
        <Step>
          <Name>LC-User-Profile</Name>
        </Step>
        <Step>
          <Name>EV-Cached-User-Profile</Name>
          <Condition>user_profile != null</Condition>
        </Step>
        <Step>
          <Name>SC-Atlassian-Me</Name>
          <Condition>user_profile == null</Condition>
        </Step>
        <Step>
          <Name>EV-Atlassian-Me</Name>
          <Condition>(user_profile == null) and (meResponse.status.code = 200)</Condition>
        </Step>
        <Step>
          <Name>PC-User-Profile</Name>
          <Condition>(user_profile == null) and (meResponse.status.code = 200)</Condition>
        </Step>
        <Step>
          <Name>AM-Set-User-Profile</Name>
          <Condition>(user_profile == null) and (meResponse.status.code = 200)</Condition>
        </Step>
        <Step>
          <Name>RF-Unauthorized</Name>
          <Condition>user_profile == null</Condition>
        </Step>
        <Step>
          <Name>AM-Capture-User-Metadata</Name>
        </Step>
      </Request>
      <Response/>
      <Condition>(proxy.pathsuffix MatchesPath "/v1/mcp") and (request.verb = "POST")</Condition>
    </Flow>
    <Flow name="authv2-v1">
      <Description>Authv2 v1 Endpoint (Dynamic Client Registration / OAuth Passthrough)</Description>
      <Request>
        <Step>
          <Name>JavaScript-RewriteRegistration</Name>
        </Step>
      </Request>
      <Response>
        <Step>
          <Name>JavaScript-RewriteRegistration</Name>
          <Condition>response.status.code = 200 or response.status.code = 201</Condition>
        </Step>
      </Response>
      <Condition>(proxy.pathsuffix MatchesPath "/v1/mcp/authv2/*")</Condition>
    </Flow>
  </Flows>
  <HTTPProxyConnection>
    <BasePath>/atlassian-mcp</BasePath>
    <Properties/>
  </HTTPProxyConnection>
  <RouteRule name="no-target-options">
    <Condition>request.verb = "OPTIONS"</Condition>
  </RouteRule>
  <RouteRule name="no-target">
    <Condition>(proxy.pathsuffix MatchesPath "/oauth2/*/authorize") or (proxy.pathsuffix MatchesPath "/oauth2/authorize") or (proxy.pathsuffix MatchesPath "/oauth2/callback")</Condition>
  </RouteRule>
  <RouteRule name="oauth">
    <Condition>(proxy.pathsuffix MatchesPath "/oauth2/**") or (proxy.pathsuffix MatchesPath "/v1/mcp/authv2/*")</Condition>
    <TargetEndpoint>atlassian-oauth</TargetEndpoint>
  </RouteRule>
  <RouteRule name="default">
    <TargetEndpoint>atlassian-mcp</TargetEndpoint>
  </RouteRule>
</ProxyEndpoint>
