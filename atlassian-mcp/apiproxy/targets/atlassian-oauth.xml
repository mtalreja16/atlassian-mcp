<TargetEndpoint name="atlassian-oauth">
  <Description>Downstream Atlassian OAuth server target</Description>
  <FaultRules/>
  <PreFlow name="PreFlow">
    <Request>
      <Step>
        <Name>AM-Clean-Accept-Encoding</Name>
      </Step>
      <Step>
        <Name>AM-Set-OASM-Target-Path</Name>
        <Condition>(proxy.name = "oasm-endpoint") and (tenant_id != null)</Condition>
      </Step>
      <Step>
        <Name>AM-Set-OASM-Target-Path-Global</Name>
        <Condition>(proxy.name = "oasm-endpoint") and (tenant_id == null)</Condition>
      </Step>
      <Step>
        <Name>AM-Set-OIDC-Target-Path</Name>
        <Condition>(proxy.name = "mcp-resource") and (proxy.pathsuffix MatchesPath "/oauth2/*/.well-known/openid-configuration") and (tenant_id != null)</Condition>
      </Step>
      <Step>
        <Name>AM-Set-OAuth-Target-Path</Name>
        <Condition>(proxy.name = "mcp-resource") and ((proxy.pathsuffix MatchesPath "/oauth2/*/token") or (proxy.pathsuffix MatchesPath "/oauth2/token"))</Condition>
      </Step>
      <Step>
        <Name>JavaScript-RewriteTokenRedirectUri</Name>
        <Condition>(proxy.name = "mcp-resource") and ((proxy.pathsuffix MatchesPath "/oauth2/*/token") or (proxy.pathsuffix MatchesPath "/oauth2/token"))</Condition>
      </Step>
      <Step>
        <Name>AM-Set-Registration-Target-Path</Name>
        <Condition>(proxy.name = "mcp-resource") and (proxy.pathsuffix MatchesPath "/v1/mcp/authv2/*") and (tenant_id != null)</Condition>
      </Step>
    </Request>
    <Response>
      <Step>
        <Name>EV-Extract-Response-Token</Name>
        <Condition>response.status.code = 200</Condition>
      </Step>
      <Step>
        <Name>SC-Atlassian-Me-Callback</Name>
        <Condition>(response.status.code = 200) and (atlassian_access_token != null)</Condition>
      </Step>
      <Step>
        <Name>EV-Atlassian-Me-Callback</Name>
        <Condition>(response.status.code = 200) and (atlassian_access_token != null)</Condition>
      </Step>
      <Step>
        <Name>PC-User-Profile-Callback</Name>
        <Condition>(response.status.code = 200) and (atlassian_access_token != null)</Condition>
      </Step>
    </Response>
  </PreFlow>
  <PostFlow name="PostFlow">
    <Request/>
    <Response/>
  </PostFlow>
  <HTTPTargetConnection>
    <URL>https://auth.atlassian.com</URL>
  </HTTPTargetConnection>
</TargetEndpoint>
